# Server Configuration
PORT=3000

# Database Configuration
# Use 'localhost' when running the Node app directly on your host machine connecting to Dockerized Postgres.
# Use 'db' (the docker-compose service name) when running the entire stack within Docker Compose.
DATABASE_URL=postgresql://postgres:mysecretpassword@localhost:5432/todos_db

# AI Configuration
# Supported providers: gemini, groq, ollama
AI_PROVIDER=gemini
AI_MODEL=gemini-1.5-flash
AI_API_KEY=your_api_key_here
